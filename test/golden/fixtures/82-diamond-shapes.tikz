\begin{tikzpicture}
	[scale=1.0,auto=left]
	\foreach \x  in {1, 2, ..., 8}
		\foreach \y  in {1, 2, ..., 6}
			\draw [black] (\x,\y) circle (5pt);
	\foreach \x / \y in {1/1, 1/2, 1/3,1/4,1/5,1/6, 2/1,2/2,2/3,2/4,2/5,3/1,3/2,3/3,3/4,4/1,4/2,4/3,5/1,5/2,6/1}
		\draw [black,fill] (\x,\y) circle (3pt);
	\foreach \x / \y in {8/6,8/5,8/4,8/3,8/2,8/1,7/6,7/5,7/4,7/3,7/2,6/6,6/5,6/4,6/3,5/6,5/5,5/4,4/6,4/5,3/6}
		\draw (\x,\y)  node[minimum size =2pt,inner sep=2pt,diamond,draw,fill]{};
	\foreach \x  in {1, 2, ..., 8}
		\node(\x) at (\x, 0.3) {$\x$};
	\end{tikzpicture}
