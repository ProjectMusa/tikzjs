\begin{tikzpicture}[line width=1.5pt]
  % Trefoil knot T(2,3)
  % Parametric: x(t) = sin(t) + 2*sin(2t),  y(t) = cos(t) - 2*cos(2t)
  % Control points derived from tangent: dx/dt = cos(t) + 4*cos(2t), dy/dt = -sin(t) + 4*sin(2t)
  % 9 cubic Bezier segments at 40-degree intervals, dt/3 ≈ 0.2327
  \draw[blue!80!black]
    (0,-1)
    .. controls (1.16,-1.00) and (2.27,-0.35) .. (2.61,0.42)
    .. controls (2.95,1.19) and (2.50,1.97) .. (1.67,2.05)
    .. controls (0.83,2.14) and (-0.28,1.71) .. (-0.87,0.50)
    .. controls (-1.45,-0.71) and (-1.44,-1.79) .. (-0.94,-2.47)
    .. controls (-0.45,-3.15) and ( 0.45,-3.15) .. (0.94,-2.47)
    .. controls ( 1.44,-1.79) and ( 1.45,-0.51) .. (0.87,0.50)
    .. controls ( 0.28, 1.51) and (-0.83, 2.14) .. (-1.67,2.05)
    .. controls (-2.50, 1.97) and (-2.95, 1.19) .. (-2.61,0.42)
    .. controls (-2.27,-0.35) and (-1.16,-1.00) .. (0,-1);
\end{tikzpicture}
