\begin{tikzpicture}[line width=2pt]
  % Trefoil knot T(2,3) -- right-handed, 3D projection onto the plane
  % Parametric: x(t)=sin(t)+2*sin(2t),  y(t)=cos(t)-2*cos(2t)
  % Control points from tangent: dx/dt=cos(t)+4*cos(2t), dy/dt=-sin(t)+4*sin(2t)
  % 9 cubic Bezier segments (40-degree intervals, dt/3~0.2327)
  %
  % Self-intersections (crossing points):
  %   C1 = (0,   1.5)  at t_over~104.5deg, t_under~255.5deg
  %   C2 = (1.3,-0.75) at t_over~ 15.5deg, t_under~224.5deg
  %   C3 = (-1.3,-0.75) at t_over~135.5deg, t_under~344.5deg
  %
  % Over/under technique: draw full curve, erase under-strand with white,
  % redraw over-strand on top.  Segment endpoints are C +/- 0.12 * tangent_unit.

  % ── Step 1: full curve ───────────────────────────────────────────────────────
  \draw[blue!80!black]
    (0,-1)
    .. controls ( 1.16,-1.00) and ( 2.27,-0.35) .. ( 2.61, 0.42)
    .. controls ( 2.95, 1.19) and ( 2.50, 1.97) .. ( 1.67, 2.05)
    .. controls ( 0.83, 2.14) and (-0.28, 1.71) .. (-0.87, 0.50)
    .. controls (-1.45,-0.71) and (-1.44,-1.79) .. (-0.94,-2.47)
    .. controls (-0.45,-3.15) and ( 0.45,-3.15) .. ( 0.94,-2.47)
    .. controls ( 1.44,-1.79) and ( 1.45,-0.51) .. ( 0.87, 0.50)
    .. controls ( 0.28, 1.51) and (-0.83, 2.14) .. (-1.67, 2.05)
    .. controls (-2.50, 1.97) and (-2.95, 1.19) .. (-2.61, 0.42)
    .. controls (-2.27,-0.35) and (-1.16,-1.00) .. (0,-1);

  % ── Step 2: erase under-strand at each crossing (white, along under-tangent) ─
  % C1 under-tangent unit ~ (-0.790, +0.613)
  \draw[white, line width=7pt, line cap=round] ( 0.10, 1.43) -- (-0.10, 1.57);
  % C2 under-tangent unit ~ (-0.136, +0.991)
  \draw[white, line width=7pt, line cap=round] ( 1.32,-0.87) -- ( 1.28,-0.63);
  % C3 under-tangent unit ~ (+0.926, -0.378)
  \draw[white, line width=7pt, line cap=round] (-1.41,-0.71) -- (-1.19,-0.80);

  % ── Step 3: redraw over-strand at each crossing on top ───────────────────────
  % C1 over-tangent unit ~ (-0.790, -0.613)
  \draw[blue!80!black, line cap=round] ( 0.10, 1.57) -- (-0.10, 1.43);
  % C2 over-tangent unit ~ (+0.926, +0.378)
  \draw[blue!80!black, line cap=round] ( 1.19,-0.80) -- ( 1.41,-0.71);
  % C3 over-tangent unit ~ (-0.136, -0.991)
  \draw[blue!80!black, line cap=round] (-1.28,-0.63) -- (-1.32,-0.87);
\end{tikzpicture}
