{
  "name": "tikzjs",
  "version": "0.1.0",
  "description": "",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "jest --silent=false",
    "test:unit": "jest --silent=false --testPathPattern='test/unit'",
    "test:golden": "jest --silent=false --testPathPattern='test/golden'",
    "test:d3": "jest --silent=false --testPathPattern='test/d3'",
    "test:e2e": "npx playwright test",
    "gen": "peggy -o src/parser/_tikzjs.js --cache src/parser/_tikzjs.pegjs",
    "build": "tsc",
    "clean": "rm -rf ./dist",
    "start": "node ./dist/index.js",
    "golden": "bash scripts/generateGolden.sh",
    "preview": "node scripts/preview.js",
    "serve": "node scripts/server.js",
    "diff": "node scripts/visualdiff.js",
    "postinstall": "npm run gen && npm run build"
  },
  "author": "Linax Dio",
  "license": "ISC",
  "dependencies": {
    "@types/bezier-js": "^4.1.3",
    "@types/d3-zoom": "^3.0.8",
    "bezier-js": "^6.1.4",
    "d3-drag": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "jsdom": "^23.2.0",
    "mathjax-full": "^3.2.2"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-selection": "^3.0.11",
    "@types/jest": "^29.5.11",
    "@types/jsdom": "^21.1.6",
    "@types/mathjax": "^0.0.40",
    "@types/react": "^18.3.28",
    "@types/yargs": "^17.0.15",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "peggy": "^3.0.2",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "prettier": "^3.0.0",
    "react": "^19.2.4",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "exports": {
    ".": "./dist/index.js"
  }
