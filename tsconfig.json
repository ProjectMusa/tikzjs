{
  "include": [
    "src/**/*"
  ],
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "lib": [
      "DOM"
    ],
    "allowJs": true,
    "outDir": "dist/",
    "rootDir": "src/",
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "skipLibCheck": true
  }
}